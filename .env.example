# Copy to .env and fill in local secrets. Never commit real API keys.

# OpenAI SDK configuration for KnowAct graph authoring and later LLM-backed agents.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# KnowAct-specific OpenAI defaults. Override per experiment if needed.
KNOWACT_OPENAI_MODEL=gpt-4.1-mini
KNOWACT_OPENAI_TEMPERATURE=0
KNOWACT_OPENAI_TIMEOUT_SECONDS=120
KNOWACT_OPENAI_MAX_COMPLETION_TOKENS=8000

# MinerU source parsing configuration for PDF -> Parsed Source Markdown.
# agent mode uses the lightweight MinerU agent API; standard mode uses the token-backed v4 API.
KNOWACT_MINERU_API_MODE=standard
KNOWACT_MINERU_API_BASE_URL=https://mineru.net/api/v4
KNOWACT_MINERU_API_TOKEN=
KNOWACT_MINERU_MODEL_VERSION=vlm
KNOWACT_MINERU_LANGUAGE=ch
KNOWACT_MINERU_ENABLE_TABLE=true
KNOWACT_MINERU_IS_OCR=false
KNOWACT_MINERU_ENABLE_FORMULA=true
KNOWACT_MINERU_PAGE_RANGE=
KNOWACT_MINERU_TIMEOUT_SECONDS=30
KNOWACT_MINERU_MAX_WAIT_SECONDS=600
KNOWACT_MINERU_POLL_INTERVAL_SECONDS=3
KNOWACT_MINERU_MAX_PAGES_PER_TASK=200

# Aliyun OSS private staging for MinerU URL-based parsing.
# The bucket should stay private; KnowAct uploads a temporary PDF object,
# signs a short-lived GET URL for MinerU, then deletes the staging object by default.
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
KNOWACT_OSS_OBJECT_PREFIX=knowact/mineru-staging
KNOWACT_OSS_SIGNED_URL_TTL_SECONDS=3600
KNOWACT_OSS_KEEP_STAGING_OBJECTS=false
