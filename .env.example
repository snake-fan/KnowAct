# Copy to .env and fill in local secrets. Never commit real API keys.

# OpenAI SDK configuration for KnowAct graph authoring and later LLM-backed agents.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# KnowAct-specific OpenAI defaults. Override per experiment if needed.
# PDF material inputs use the Responses API and should use a model with file/vision input support.
KNOWACT_OPENAI_MODEL=gpt-4.1-mini
KNOWACT_OPENAI_TEMPERATURE=0
KNOWACT_OPENAI_TIMEOUT_SECONDS=120
KNOWACT_OPENAI_MAX_COMPLETION_TOKENS=8000
